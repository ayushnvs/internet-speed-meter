<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InternetSpeedMeter.MainPage"
             BackgroundColor="#0A0E1A">

    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="30, 50, 30, 50">
        
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="5">
            <Label Text="Speed Meter" FontSize="24" FontAttributes="Bold" TextColor="White"/>
            <Label Text="Lite" FontSize="24" FontAttributes="Bold" TextColor="#00E5FF"/>
        </HorizontalStackLayout>

        <Grid Grid.Row="1" WidthRequest="240" HeightRequest="240" HorizontalOptions="Center" VerticalOptions="Center">
            <Ellipse Stroke="#1E293B" StrokeThickness="12" WidthRequest="220" HeightRequest="220"/>
            
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                <Label x:Name="LblSpeedValue" Text="0.0" FontSize="52" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label x:Name="LblSpeedUnit" Text="K/s" FontSize="18" TextColor="#00E5FF" HorizontalOptions="Center"/>
                <Label Text="DOWNLOAD" FontSize="11" TextColor="#64748B" CharacterSpacing="1.5" Margin="0,8,0,0" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <Border Grid.Row="2" BackgroundColor="#111827" Stroke="#1F2937" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20" Margin="0,0,0,30">
            <Grid ColumnDefinitions="*, *">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label Text="Download" TextColor="#9CA3AF" FontSize="12" HorizontalOptions="Center"/>
                    <Label x:Name="LblStatDl" Text="0.0 K/s" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,4,0,0"/>
                </VerticalStackLayout>
                <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="#1E293B" HorizontalOptions="End"/>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label Text="Upload" TextColor="#9CA3AF" FontSize="12" HorizontalOptions="Center"/>
                    <Label Text="0.0 K/s" TextColor="#34D399" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,4,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Button Grid.Row="3" 
                x:Name="BtnMonitor"
                Text="Start Monitoring" 
                BackgroundColor="#2563EB" 
                TextColor="White" 
                HeightRequest="56" 
                CornerRadius="28" 
                FontAttributes="Bold" 
                FontSize="16"
                Clicked="OnMonitorClicked"/>
    </Grid>
</ContentPage>